<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MauiOefeningen.ViewModels"
             x:Class="MauiOefeningen.Views.AlleNegenPage"
             x:DataType="viewmodel:AlleNegenViewModel"
             Title="Alle negen">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12" HorizontalOptions="Center">
            <Label Text="Dit is het spelletje 'Alle negen'"
                   FontSize="34"
                   HorizontalTextAlignment="Center" />
            <Label Text="Gooi met twee dobbelstenen en klik daarna maximum 2 cijfers weg tot het totaal van de twee dobbelstenen bereikt is."
                   HorizontalTextAlignment="Center" />
            <Label Text="Probeer alle getallen weg te krijgen. Tracht een zo laag mogelijke score te bereiken."
                   HorizontalTextAlignment="Center" />
            <Button Text="Gooi"
                    WidthRequest="220"
                    Command="{Binding GooiCommand}"
                    IsEnabled="{Binding GooiEnabled}" />
            <HorizontalStackLayout Spacing="40" HorizontalOptions="Center">
                <Label Text="{Binding Dobbel1}" FontSize="48" />
                <Label Text="{Binding Dobbel2}" FontSize="48" />
            </HorizontalStackLayout>
            <CollectionView ItemsSource="{Binding Getallen}"
                            SelectionMode="None"
                            WidthRequest="220">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodel:AlleNegenViewModel.GetalTile">
                        <Button Text="{Binding Tekst}"
                                HeightRequest="52"
                                WidthRequest="52"
                                Margin="6"
                                IsEnabled="{Binding IsEnabled}"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.KiesGetalCommand}"
                                CommandParameter="{Binding Nummer}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Label Text="{Binding Melding}" HorizontalTextAlignment="Center" />
            <Button Text="Herstart"
                    WidthRequest="220"
                    Command="{Binding HerstartCommand}"
                    IsEnabled="{Binding HerstartEnabled}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>