<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MauiOefeningen.ViewModels"
             x:DataType="viewmodel:NaamTonenViewModel"
             x:Class="MauiOefeningen.Views.NaamTonenPage"
             Title="Naam tonen">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <Label Text="Naam tonen"
                   FontSize="36"/>
            <Grid ColumnDefinitions="180,*"
                  RowDefinitions="Auto,Auto,Auto"
                  ColumnSpacing="12"
                  RowSpacing="12">

                <Label Grid.Row="0" Grid.Column="0"
                       Text="Geef een naam in:"
                       VerticalTextAlignment="Center" />
                <Entry Grid.Row="0" Grid.Column="1"
                       Text="{Binding Naam}" />
                <Label Grid.Row="1" Grid.Column="0"
                       Text="Geef een getal in:"
                       VerticalTextAlignment="Center" />
                <Entry Grid.Row="1" Grid.Column="1"
                       Keyboard="Numeric"
                       WidthRequest="80"
                       HorizontalOptions="Start"
                       Text="{Binding Aantal}" />

                <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2" Spacing="12">
                    <Button Text="Naam tonen"
                            Command="{Binding NaamTonenCommand}"
                            HeightRequest="56"
                            WidthRequest="200" />
                    <Button Text="Resultaat leegmaken"
                            Command="{Binding ResultaatLeegmakenCommand}"
                            HeightRequest="56"
                            WidthRequest="200" />
                </HorizontalStackLayout>
            </Grid>
            <Label Text="{Binding Resultaat}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>