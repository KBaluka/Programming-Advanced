<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MauiOefeningen.ViewModels"
             x:DataType="viewmodel:AfbeeldingenViewModel"
             x:Class="MauiOefeningen.Views.AfbeeldingenPage"
             Title="Afbeeldingen">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Text="Afbeeldingen"
                   FontSize="36"
                   FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Label Text="Selecteer een getal:"
                       FontSize="18"
                       VerticalTextAlignment="Center" />
                <Label Text="{Binding GeselecteerdGetal, StringFormat='{0:0}'}"/>
                <Stepper Minimum="1"
                         Maximum="5"
                         Increment="1"
                         Value="{Binding GeselecteerdGetal}" />
            </HorizontalStackLayout>

            <Button Text="Afbeelding tonen"
                    WidthRequest="280"
                    HeightRequest="60"
                    Command="{Binding AfbeeldingTonenCommand}"
                    HorizontalOptions="Start" />
            <Image Source="{Binding AfbeeldingBron}"
                   HeightRequest="500"
                   WidthRequest="1000"
                   Aspect="AspectFill" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>