<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:MauiOefeningen.Models"
             x:Class="MauiOefeningen.Views.PersonenTonenPage"
             Title="Personen tonen">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12" WidthRequest="320">
            <Label Text="Personen tonen" FontSize="26" FontAttributes="Bold" />
            <Label Text="Personen" FontAttributes="Bold" />
            <CollectionView x:Name="PersonenList" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Persoon">
                        <VerticalStackLayout Spacing="0" Margin="0,6,0,0">
                            <Label Text="{Binding Voornaam, StringFormat='Voornaam: {0}'}" />
                            <Label Text="{Binding Geboortedatum, StringFormat='Geboortedatum: {0:dd/MM/yyyy}'}" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <Label x:Name="ResultaatLabel" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>